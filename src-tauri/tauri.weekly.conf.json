{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gpt Orbit Weekly",
  "mainBinaryName": "gpt-orbit-weekly",
  "identifier": "com.codex-orbit.weekly",
  "build": {
    "beforeDevCommand": "npm run dev:weekly",
    "beforeBuildCommand": "npm run build:weekly"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 104,
